---
import Layout from "../layouts/Layout.astro";

const academy = {
	name: "Danzahr Studio",
	handle: "@danzahr.studio",
	description:
		"Danza árabe, energía y expresión en cada movimiento. Un espacio para conectar con la música, el cuerpo y la alegría. ✨💃",
	profileImage: `${import.meta.env.BASE_URL}images/profile.jpeg`,
	backgroundImage: `${import.meta.env.BASE_URL}images/danza-arabe-fondo.jpg`,
};

const socialLinks = [
	{
		name: "Instagram",
		href: "https://www.instagram.com/danzahr.studio?igsh=cXh2NGw4d3A5MGdk",
		icon: "instagram",
	},
	{
		name: "Facebook",
		href: "https://www.facebook.com/share/1EorMQLkks/?mibextid=wwXIfr",
		icon: "facebook",
	},
	{
		name: "TikTok",
		href: "https://www.tiktok.com/@danzahr.studio?_r=1&_t=ZS-959vsJgWhk1",
		icon: "tiktok",
	},
	{
		name: "YouTube",
		href: "https://youtube.com/@danzahr.studio?si=0nAgIQVsUBsYL7W3",
		icon: "youtube",
	},
];

const mainLinks = [
  { title: "Contacto por WhatsApp", href: "https://wa.me/" },
	{ title: "Clases", href: "https://wa.me/", disabled: true },
	{
		title: "Horarios y niveles",
		href: "https://wa.me/",
		disabled: true,
	},
	{ title: "Inscripciones", href: "https://wa.me/", disabled: true },
	{
		title: "Presentaciones",
		href: "https://www.instagram.com/danzahr.studio?igsh=cXh2NGw4d3A5MGdk",
		disabled: true,
	},
];
---

<Layout
	title='Academia de Baile Angélica'
	description='Landing mobile first para la Academia de Baile Angélica con foto de perfil, redes y enlaces principales.'
>
	<main class='page' style={`--bg-image: url('${academy.backgroundImage}');`}>
		<div class='backdrop'></div>

		<section class='shell'>
			<header class='hero'>
				<img
					class='avatar'
					src={academy.profileImage}
					alt={`Foto de perfil de ${academy.name}`}
					loading='eager'
				/>

				<p class='handle'>{academy.handle}</p>
				<h1>{academy.name}</h1>
				<p class='description'>{academy.description}</p>
			</header>

			<nav class='socials' aria-label='Redes sociales'>
				{
					socialLinks.map((social) => (
						<a
							href={social.href}
							target='_blank'
							rel='noreferrer'
							aria-label={social.name}
						>
							{social.icon === "instagram" && (
								<svg
									class='social-icon'
									viewBox='0 0 24 24'
									aria-hidden='true'
								>
									<path d='M7.8,2H16.2C19.4,2 22,4.6 22,7.8V16.2A5.8,5.8 0 0,1 16.2,22H7.8C4.6,22 2,19.4 2,16.2V7.8A5.8,5.8 0 0,1 7.8,2M7.6,4A3.6,3.6 0 0,0 4,7.6V16.4C4,18.39 5.61,20 7.6,20H16.4A3.6,3.6 0 0,0 20,16.4V7.6C20,5.61 18.39,4 16.4,4H7.6M17.25,5.5A1.25,1.25 0 0,1 18.5,6.75A1.25,1.25 0 0,1 17.25,8A1.25,1.25 0 0,1 16,6.75A1.25,1.25 0 0,1 17.25,5.5M12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9Z' />
								</svg>
							)}
							{social.icon === "facebook" && (
								<svg
									class='social-icon'
									viewBox='0 0 16 16'
									aria-hidden='true'
								>
									<path d='M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951' />
								</svg>
							)}
							{social.icon === "tiktok" && (
								<svg
									class='social-icon'
									viewBox='0 0 24 24'
									aria-hidden='true'
								>
									<path d='M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z' />
								</svg>
							)}
							{social.icon === "youtube" && (
								<svg
									class='social-icon'
									viewBox='0 0 24 24'
									aria-hidden='true'
								>
									<path d='M10,15L15.19,12L10,9V15M21.56,7.17C21.69,7.64 21.78,8.27 21.84,9.07C21.91,9.87 21.94,10.56 21.94,11.16L22,12C22,14.19 21.84,15.8 21.56,16.83C21.31,17.73 20.73,18.31 19.83,18.56C19.36,18.69 18.5,18.78 17.18,18.84C15.88,18.91 14.69,18.94 13.59,18.94L12,19C7.81,19 5.2,18.84 4.17,18.56C3.27,18.31 2.69,17.73 2.44,16.83C2.31,16.36 2.22,15.73 2.16,14.93C2.09,14.13 2.06,13.44 2.06,12.84L2,12C2,9.81 2.16,8.2 2.44,7.17C2.69,6.27 3.27,5.69 4.17,5.44C4.64,5.31 5.5,5.22 6.82,5.16C8.12,5.09 9.31,5.06 10.41,5.06L12,5C16.19,5 18.8,5.16 19.83,5.44C20.73,5.69 21.31,6.27 21.56,7.17Z' />
								</svg>
							)}
						</a>
					))
				}
			</nav>

			<section class='support' aria-label='Invítame un café en Ko-fi'>
				<div class='kofi-widget'>
					<script
						is:inline
						type='text/javascript'
						src='https://storage.ko-fi.com/cdn/widget/Widget_2.js'
					></script>
					<script is:inline type='text/javascript'>
						kofiwidget2.init('Invítame un café', '#eed69cb3', 'G2G51XUIG9');
						kofiwidget2.draw();
					</script>
				</div>
			</section>

			<section class='links' aria-label='Enlaces principales'>
				{
					mainLinks.map((link) => (
						link.disabled ? (
							<div class='link-card is-disabled' aria-disabled='true'>
								<span>{link.title}</span>
								<span class='badge'>Próximamente</span>
							</div>
						) : (
							<a
								class='link-card'
								href={link.href}
								target='_blank'
								rel='noreferrer'
							>
								<span>{link.title}</span>
								<span class='chevron' aria-hidden='true'>
									+
								</span>
							</a>
						)
					))
				}
			</section>
		</section>
	</main>
</Layout>

<style>
	:root {
		--gold: #bb9157;
		--gold-soft: #d3b081;
		--ink: #050505;
		--paper: #f4eee6;
	}

	.page {
		position: relative;
		min-height: 100vh;
		overflow-x: hidden;
		background-image:
			linear-gradient(180deg, rgba(5, 5, 5, 0.4), rgba(5, 5, 5, 0.8)),
			var(--bg-image);
		background-position: center;
		background-repeat: no-repeat;
		background-size: cover;
	}

	.backdrop {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(
				circle at top right,
				rgba(187, 145, 87, 0.28),
				transparent 28%
			),
			radial-gradient(
				circle at bottom left,
				rgba(187, 145, 87, 0.22),
				transparent 24%
			);
	}

	.shell {
		position: relative;
		z-index: 1;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		padding: 24px 16px 36px;
	}

	.hero {
		width: 100%;
		max-width: 28rem;
		box-sizing: border-box;
		margin: 0;
		padding: 24px 20px 22px;
		border-radius: 30px;
		background: rgba(13, 13, 13, 0.62);
		border: 1px solid rgba(211, 176, 129, 0.28);
		backdrop-filter: blur(12px);
		box-shadow: 0 22px 60px rgba(0, 0, 0, 0.34);
		text-align: center;
	}

	.avatar {
		width: 108px;
		height: 108px;
		object-fit: cover;
		display: block;
		margin: 0 auto 16px;
		border-radius: 999px;
		border: 3px solid rgba(211, 176, 129, 0.95);
		box-shadow: 0 12px 26px rgba(0, 0, 0, 0.28);
	}

	.handle,
	h1,
	.description {
		margin: 0;
	}

	.handle {
		font-size: 0.74rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: rgba(211, 176, 129, 0.88);
	}

	h1 {
		margin-top: 8px;
		font-size: clamp(2rem, 8vw, 3.3rem);
		line-height: 0.98;
		color: var(--paper);
		text-wrap: balance;
	}

	.description {
		margin-top: 14px;
		font-size: 0.98rem;
		line-height: 1.6;
		color: rgba(244, 238, 230, 0.88);
	}

	.socials,
	.support,
	.links {
		width: 100%;
		max-width: 28rem;
		box-sizing: border-box;
		margin: 14px 0 0;
	}

	.socials {
		display: flex;
		gap: 10px;
		justify-content: center;
		flex-wrap: wrap;
	}

	.socials a {
		width: 48px;
		height: 48px;
		display: grid;
		place-items: center;
		border-radius: 999px;
		background: rgba(187, 145, 87, 0.14);
		border: 1px solid rgba(211, 176, 129, 0.28);
		color: var(--paper);
		text-decoration: none;
		transition:
			transform 180ms ease,
			filter 180ms ease,
			background 180ms ease;
	}

	.socials svg {
		fill: currentColor;
	}

	.social-icon {
		width: 30px;
		height: 30px;
		display: block;
	}

	.support {
		display: flex;
		justify-content: center;
		align-items: center;
		padding: 18px 0;
		border-top: 1px solid rgba(211, 176, 129, 0.28);
		border-bottom: 1px solid rgba(211, 176, 129, 0.28);
	}

	.kofi-widget {
		display: flex;
		justify-content: center;
		align-items: center;
		width: 100%;
	}

  .kofi-widget :global(.btn-container) {
    min-width: 100% !important;
  }

	.kofi-widget :global(a) {
		display: flex !important;
		flex-direction: row !important;
		flex-wrap: nowrap !important;
		align-items: center !important;
		gap: 10px;
		grid-auto-flow: column;
		grid-template-columns: auto 1fr;
		width: 100% !important;
		max-width: 100% !important;
		box-sizing: border-box;
		padding: 16px 18px !important;
		border: 1px solid rgba(211, 176, 129, 0.22) !important;
		border-radius: 20px !important;
		background: linear-gradient(
			145deg,
			rgba(238, 214, 156, 0.7),
			rgba(239, 231, 218, 0.7)
		) !important;
		box-shadow: 0 14px 26px rgba(0, 0, 0, 0.2) !important;
		color: var(--ink) !important;
		font-weight: 700 !important;
		text-decoration: none !important;
		text-align: center;
		transition:
			transform 180ms ease,
			filter 180ms ease,
			box-shadow 180ms ease !important;
	}

  .kofi-widget :global(img.kofiimg) {
    width: 2.567rem !important;
    height: 1.75rem !important;
    margin: 0 !important;
  }

  .kofi-widget :global(.kofitext) {
    font-family: "Instrument Sans", "Segoe UI", sans-serif;
    font-size: 1.05rem !important;
    line-height: 1.75rem !important;
  }

	.kofi-widget :global(span),
	.kofi-widget :global(a > :not(img)) {
		color: var(--ink) !important;
    gap: 1rem;
	}

	.kofi-widget :global(span) {
		display: inline-flex !important;
		align-items: center !important;
		justify-content: center !important;
		white-space: nowrap;
	}

	.kofi-widget :global(a:hover),
	.kofi-widget :global(a:focus-visible),
	.kofi-widget :global(.kofiimg:hover),
	.kofi-widget :global(.kofiimg:focus-visible) {
		transform: translateY(-2px);
		filter: brightness(1.05);
		outline: none;
	}

	.links {
		display: grid;
		gap: 12px;
	}

	.link-card {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		min-height: 62px;
		padding: 16px 18px;
		border-radius: 20px;
		background: linear-gradient(
			145deg,
			rgba(238, 214, 156, 0.7),
			rgba(239, 231, 218, 0.7)
		);
		color: var(--ink);
		text-decoration: none;
		font-weight: 700;
		box-shadow: 0 14px 26px rgba(0, 0, 0, 0.2);
		transition:
			transform 180ms ease,
			filter 180ms ease;
	}

	.link-card.is-disabled {
		background: linear-gradient(
			135deg,
			rgba(238, 214, 156, 0.4),
			rgba(239, 231, 218, 0.4)
		);
		color: rgba(0, 0, 0, 1);
    text-shadow: 1px 1px 1px rgba(238, 214, 156, 0.7);
		cursor: not-allowed;
		pointer-events: none;
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.12);
	}

	.badge {
		position: absolute;
		top: 16px;
		right: 18px;
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 6px 12px;
		border-radius: 999px;
		background:
			linear-gradient(
				145deg,
        rgba(238, 214, 156, 0.7),
        rgba(239, 231, 218, 0.7)
			),
			rgba(5, 5, 5, 0.7);
		border: 1px solid rgba(255, 248, 236, 0.36);
		box-shadow:
			0 10px 22px rgba(0, 0, 0, 0.18),
			inset 0 1px 0 rgba(255, 255, 255, 0.2);
		color: #000000;
    text-shadow: 1px 1px 1px rgba(238, 214, 156, 0.7);
		font-size: 0.64rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		line-height: 0.3rem;
		text-shadow: 0 1px 0 rgba(255, 255, 255, 0.2);
		backdrop-filter: blur(10px);
		overflow: hidden;
	}

	.badge::before {
		content: "";
		width: 6px;
		height: 6px;
		border-radius: 999px;
		background: #fff8ec;
		box-shadow: 0 0 0 4px rgba(255, 248, 236, 0.18);
		flex: none;
	}

	.badge::after {
		content: "";
		position: absolute;
		inset: 0;
		background: linear-gradient(
			120deg,
			transparent 0%,
			rgba(255, 255, 255, 0.22) 45%,
			transparent 70%
		);
		transform: translateX(-140%);
		transition: transform 260ms ease;
	}

	.link-card.is-disabled:hover .badge::after,
	.link-card.is-disabled:focus-visible .badge::after {
		transform: translateX(140%);
	}

	.link-card:hover,
	.link-card:focus-visible,
	.socials a:hover,
	.socials a:focus-visible {
		transform: translateY(-2px);
		filter: brightness(1.05);
		outline: none;
	}

	.chevron {
		font-size: 1.25rem;
		line-height: 1;
	}

	@media (min-width: 768px) {
		.shell {
			justify-content: center;
			padding: 40px 24px;
		}

		.hero {
			width: min(100%, 31rem);
			padding: 30px 28px 24px;
		}

		.socials,
		.support,
		.links {
			width: min(100%, 31rem);
		}

		.avatar {
			width: 122px;
			height: 122px;
		}
	}
</style>
