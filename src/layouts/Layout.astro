---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Danzahr | Links',
	description = 'Landing minimalista estilo linktree creada con Astro.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	:root {
		color-scheme: dark;
		font-family:
			"Instrument Sans",
			"Segoe UI",
			sans-serif;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		background: #120f1f;
	}

	body {
		min-height: 100vh;
	}

	* {
		box-sizing: border-box;
	}
</style>
